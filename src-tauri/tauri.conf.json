      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBM0Q1RDBDNEFCNzI5N0UKUldSK0tiZEtERjA5MnRSY1dSNWlFU3dUK3JhOGlaWGJEa2NTZ3hnVFVRNENVVnJDUnhMNWVyTkwK",
